{
  "name": "kaimaison-clone",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js --host 0.0.0.0",
    "build": "npm run optimize:assets && node ./node_modules/vite/bin/vite.js build && npm run prepare:pages",
    "preview": "node ./node_modules/vite/bin/vite.js preview --host 0.0.0.0",
    "optimize:assets": "node scripts/optimize-assets.mjs",
    "prepare:pages": "node scripts/prepare-pages.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}